# ============================================================================
# Lipi — .gitignore
# Fabric Loom / Gradle / VS Code / Windows
# ============================================================================

# ---------- Gradle ----------
.gradle/
build/

# ---------- VS Code / Eclipse (Java Extension) ----------
# bin/ is generated by VS Code's Java language server (compiled .class files)
.vscode/
bin/
.classpath
.project
.settings/
.factorypath

# ---------- IntelliJ IDEA ----------
.idea/
*.iml
*.iws
*.ipr
out/

# ---------- Fabric Loom ----------
# run/ is created by runClient / runServer tasks — contains a full MC instance
run/
# Loom remapped intermediates (normally inside build/, listed here for safety)
remappedSrc/

# ---------- Mod runtime output (generated during testing) ----------
# Lipi writes chat logs here when run locally
config/lipi/logs/

# ---------- OS junk ----------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ---------- Java ----------
*.class
*.jar
*.war
*.ear
hs_err_pid*
replay_pid*

# ---------- Explicit inclusions ----------
# Gradle wrapper MUST be committed (required for ./gradlew to work)
!**/gradle/wrapper/gradle-wrapper.jar
!**/gradle/wrapper/gradle-wrapper.properties
